(* regolith grammar.ebnf -- WO-05 conformance/documentation deliverable.
 *
 * Normative order: this file documents crates/regolith-syntax's
 * hand-written recursive-descent parser (crates/regolith-syntax/src/
 * parser.rs); the parser wins on any drift (it is what actually runs
 * against examples/). Extension strings (.hema/.cupr) are NOT spelled
 * out here -- they live in exactly one place, the registry module
 * crates/regolith-syntax/src/extension.rs (00-architecture.md AD-14
 * risk register; ground rule 6).
 *
 * Layout (regolith/08): indentation is space-only (a tab in
 * indentation is an E01xx diagnostic); INDENT/DEDENT/NEWLINE are
 * synthesized by the off-side-rule layout pass ahead of parsing, so
 * the grammar below is written as if they were ordinary tokens.
 *
 * Scope note (WO-05 residual promotion): the former residual
 * opaque constructs are now TYPED CST nodes -- `stage`/`setup`
 * machining blocks, `impl ... for ... [as ...]` role bindings,
 * `connect`, `parts`, `zones`, `boundary`, `flows` blocks, `policy`
 * rule lines (`prefer`/`forbid`/`minimize`/`maximize`/`use`),
 * declaration-header generic-parameter lists, and the WO-11 `walk`
 * sub-grammar (walk steps, `hole`/`regions`/`constraints`/`exports`).
 * WO-28 adds the typed rule-pack surface inside `process` decls
 * (capability-block, rule-pack-block, rule-decl, forall/resolves/
 * expect -- see the rule-packs section below).
 * Bracketed continuations are implicitly line-joined by the layout
 * pass (Python-style), so a multi-line call/interval/import argument
 * list is one logical line. What remains `opaque-stmt` /
 * opaque-continuation is only the genuinely deferred residue: value-
 * expression tails the value grammar does not model (e.g. a
 * space-separated `1 N*m` unit product), multi-line claim-expression
 * continuations (a next line led by an operator), and Ident-led
 * statements with no promoted shape (`override`, `plan:`, `flip ...`).
 * This is structure-recorded-semantics-deferred, not unparsed. A
 * stray CLOSING bracket at statement position is the one genuine
 * malformation: `subject-error` (E0193), attributed to the enclosing
 * declaration subject for INV-20 per-subject gating.
 *)

file            = { import-stmt | decl | medium-decl | flownet-decl
                  | require-decl } ;

import-stmt     = "import" , rest-of-line ;   (* header line only, no body *)

(* --- fluorite top-level declarations (WO-31; fluorite/02 RATIFIED v1,
 * D93). `medium`/`flownet`/`reference`/`nodes`/`edges`/`states` are
 * CONTEXTUAL idents recognized only at statement/decl-start (cycle 18
 * D85 idiom), NEVER new lexer keywords; `require` is the existing
 * keyword hoisted to decl position. The arrow-shaped sense pair
 * `(<a> -> <b>)` and the `{...}` state-domain set are NOT new tokens:
 * `->` lexes as `-` `>` and `{`/`}` are Error bytes, both recorded
 * losslessly as an edge/state value tail (structure recorded, sense/
 * domain typing deferred to a later WO-31 increment).
 *)

medium-decl     = "medium" , ident , rest-of-line ,
                  [ INDENT , stmt-block , DEDENT ] ;
                (* the phase word (`liquid`/`gas`) rides in the header
                   line; the body is `props: registry(...)` fields *)

flownet-decl    = "flownet" , ident , rest-of-line ,
                  [ INDENT , flownet-body , DEDENT ] ;
                (* the `(medium=<ref>)` config rides in the header line *)

flownet-body    = { edges-block | states-block | field | ctor-stmt
                  | opaque-stmt } ;
                (* `reference:`/`nodes:` are ordinary fields *)

edges-block     = "edges" , ":" , NEWLINE ,
                  [ INDENT , { edge-stmt } , DEDENT ] ;
edge-stmt       = ident , ":" , value , [ opaque-tail ] ,
                  [ INDENT , stmt-block , DEDENT ] ;
                (* value is the component constructor `CallExpr`; the
                   `(<a> -> <b>)` sense pair rides as opaque-tail (same
                   line) or a nested opaque continuation (next line) *)

states-block    = "states" , ":" , NEWLINE ,
                  [ INDENT , { state-stmt } , DEDENT ] ;
state-stmt      = rest-of-line ;
                (* `<edge>.<param> in {...}`, `state <name> in {...}`,
                   or a commanded `event <edge>.<x>: ...` line *)

require-decl    = "require" , ident , rest-of-line ,
                  [ INDENT , stmt-block , DEDENT ] ;
                (* the decl-position claim group; claim lines are fields
                   over the existing claim-expression grammar *)

(* --- top-level declarations ------------------------------------- *)

decl-keyword    = "part" | "profile" | "interface" | "mating" | "assembly"
                | "system" | "block" | "impl" | "component" | "protocol"
                | "computer" | "image" | "board" | "target" | "datum"
                | "event" ;

decl            = decl-keyword , [ ident ] , [ generic-params ] ,
                  rest-of-line , [ INDENT , stmt-block , DEDENT ] ;
                (* the name and any generic-parameter list are lifted out
                   as typed nodes; the remaining header (`for <target>`,
                   `as <alias>`, trailing config) is consumed as tokens *)

generic-params  = "<" , { any-token | generic-params } , ">" ;
                (* one node, balanced angle nesting (`PatternOf<CBore<M8>>`);
                   individual params are not decomposed (a partial node) *)

(* --- the shared statement-block grammar --------------------------
 * `decl`, `then-scope`, `require-claim`, `budget-stmt`, `waive-block`,
 * `policy-block`, and `locked-block` all nest this same block.
 *)

stmt-block      = { field | ctor-stmt | reg-assign | then-scope
                   | require-claim | budget-stmt | waive-block | policy-block
                   | locked-block | impl-stmt | on-block | domain-block
                   | ownership-stmt | region-stmt | symmetry-stmt
                   | realizes-stmt
                   | hint-stmt
                   | policy-rule | subject-error | opaque-stmt } ;

(* --- hint annotation (regolith/12 rung 3, INV-03) ---
 * `@hint(...)` is a verdict-inert single-line leaf, recognized at
 * statement-start by its leading `@` sigil and swallowed whole. No
 * lowering pass reads it, so it perturbs no obligation/resolution: the
 * structural proof of hint droppability. `policy: prefer` (rung 3's soft
 * half) is the existing `policy-block`/`policy-rule`; it only reorders
 * candidate exploration, never a verdict.
 *)
hint-stmt       = "@" , rest-of-line ;

(* --- promoted typed domain constructs (WO-05 residual, WO-11 walk) ---
 * `stage`/`setup`/`connect`/`parts`/`zones`/`boundary`/`flows`/`walk`/
 * `hole`/`regions`/`constraints`/`exports` are contextual block words:
 * recognized ONLY at statement-start (they also occur as ordinary path
 * segments in value position, so they are NOT lexer keywords). Each is
 * a header line + an indented body; a `walk:` body parses walk-steps, a
 * `workloads:` body parses workload-stmt lines (cuprite/05 sec. 1), every
 * other body is the shared stmt-block.
 *)
domain-block    = block-word , rest-of-line ,
                  [ INDENT , ( walk-block | workloads-block | stmt-block ) , DEDENT ] ;
block-word      = "stage" | "setup" | "connect" | "parts" | "zones"
                | "boundary" | "flows" | "walk" | "hole" | "regions"
                | "constraints" | "exports" | "workloads" ;

impl-stmt       = "impl" , rest-of-line , [ INDENT , stmt-block , DEDENT ] ;

(* --- typed ownership/region/symmetry statements (WO-05 residual
 * promotion, WO-19 delta/region population; INV-04/05/23) ---
 * Single-line typed leaves. Like block-words these verbs are contextual,
 * NOT lexer keywords (`region`/`route`/`pattern` also occur as path
 * segments / field names): recognized ONLY at statement-start and ONLY
 * with an argument follower -- an `ident` for all verbs, and `(` for the
 * call-like mirror verbs (`symmetric`/`mirror`/`flip`/`break`/`any`), so
 * a coincidental `region:` field or `route = x` ctor is never promoted.
 * The lowering pass reads the leading verb + argument idents back off the
 * node's tokens to populate `BorrowTable`, `EntityKind::Region` +
 * `PredictedDelta.regions_touched`, and the `OrbitTable`.
 *)
ownership-stmt  = ( "bind" | "modify" ) , ident , rest-of-line ;
region-stmt     = ( ( "region" | "keepout" ) , ident ,
                    [ "exclusion" | "arbitration" ] )
                | ( "route" , ident , ( "into" | "join" ) , ident ) ,
                  rest-of-line ;
symmetry-stmt   = ( "pattern" , ident , ( "circular" | "linear" ) , number )
                | ( "break" , ident )
                | ( "any" , ident )
                | ( ( "symmetric" | "mirror" | "flip" ) , rest-of-line ) ;

(* --- cuprite computer-track: workloads / realizes (cuprite/05 sec. 1;
 * EOPEN-15 resolved). Promoted from OpaqueIsland: a `workloads:` block
 * (contextual block-word, like `parts:`) whose body is one workload-stmt
 * per line. The parameter group `(...)` is recorded whole (balanced,
 * not decomposed -- like generic-params) since it mixes claim/field/ctor
 * shapes (`rate=1kHz`, `jitter <= 50us`, `state: 64kB`) the statement
 * value-grammar does not unify. A `realizes` clause is a typed leaf like
 * `ownership-stmt`/`symmetry-stmt`: recognized standalone at
 * statement-start with an `ident` follower, AND nested as a
 * `workload-stmt`'s trailing clause (the corpus shape: `att: loop(...)
 * realizes decide`).
 *)
workloads-block = { workload-stmt } ;
workload-stmt   = name-path , ":" , ident , [ "(" , workload-params , ")" ] ,
                  [ realizes-stmt ] , rest-of-line ;
workload-params = { any-token | "(" , workload-params , ")" } ;
                (* one node, balanced paren nesting; individual params
                   are not decomposed (a partial node, like generic-params) *)
realizes-stmt   = "realizes" , ident , { "," , ident } , rest-of-line ;

(* --- rule packs (WO-28; hematite/02 sec. 10, hematite/04 sec. I5,
 * cuprite/04 sec. 4; design 21-rule-packs D-B / AD-21) ---
 * A `process` declaration is Ident-led: `process` is CONTEXTUAL, never
 * a lexer keyword, because it also appears as `process=<module>` in
 * every stage header (cycle 18 D85). Its body is the shared stmt-block
 * grammar PLUS context-sensitive words, nested one level at a time:
 * process body -> pack block -> rule body -> expect body. Every word
 * below is likewise contextual (statement-start + required follower
 * only), so `dfm(rule)` waive targets, `capability.x` value paths, and
 * coincidental `dfm: 5` fields outside process bodies never promote.
 * Anything unrecognized at each level falls back to the shared
 * statement grammar (fields, ctors, subject-error, opaque), so a
 * malformed rule degrades per statement -- batch diagnostics, never
 * eating the block (AD-3).
 *)
process-decl     = "process" , ident , rest-of-line ,
                   [ INDENT , process-body , DEDENT ] ;
process-body     = { capability-block | rule-pack-block | stmt-block } ;
capability-block = "capability" , ":" , NEWLINE ,
                   [ INDENT , stmt-block , DEDENT ] ;
rule-pack-block  = ( "dfm" | "drc" | "erc" ) , ":" , NEWLINE ,
                   [ INDENT , { rule-decl | stmt-block } , DEDENT ] ;
rule-decl        = "rule" , ident , ":" , rest-of-line ,
                   [ INDENT , rule-body , DEDENT ] ;
rule-body        = { forall-clause | resolves-clause | expect-block
                   | field    (* demand:/advise:/per:/why: are ordinary
                                 fields over the claim-expression
                                 grammar; aggregates (`sum(...)`) and
                                 record dereference (`n.driver.i_drive`)
                                 are existing CallExpr/Path shapes *)
                   | stmt-block } ;
forall-clause    = "forall" , ident , "in" , expr , rest-of-line ;
                 (* the settled claim quantifier with an entity query as
                    the domain; unmodeled query tails (boolean filter
                    connectives) are swept losslessly INSIDE the clause
                    (cycle 18 F95) *)
resolves-clause  = "resolves" , ":" , name-path , "from" , "free" ,
                   rest-of-line ;
expect-block     = "expect" , ":" , NEWLINE ,
                   [ INDENT , { expect-case | stmt-block } , DEDENT ] ;
expect-case      = ( "pass" | "fail" ) , ":" , value-tail ;

(* WO-11 walk sub-grammar: each line is a walk-step leaf (`from <datum>`,
 * `line`/`arc` + direction/join words, `bulge=`, `close [via axis]`),
 * except a nested `hole <name>:` which opens its own block (one level).
 *)
walk-block      = { ( "hole" , rest-of-line ,
                      [ INDENT , stmt-block , DEDENT ] ) | walk-step } ;
walk-step       = rest-of-line ;

policy-rule     = ( "prefer" | "forbid" | "minimize" | "maximize" | "use" ) ,
                  rest-of-line ;

(* --- typed elec behavioral-layer constructs (WO-05 residual promotion,
 * WO-19 converter-graph population; cuprite/03, INV-16) ---
 * `on <event>:` is a clocked synchronous-reactive body (`on` is the
 * registered spatial/temporal guard keyword `OnKw`): a header line + an
 * indented stmt-block. Inside it, `<=` lines are non-blocking register
 * assignments (ZOH deltas) and `=` lines are combinational. A `reg-assign`
 * has the ctor shape but the `<=` operator; it is recognized wherever a
 * statement can start (the lowering pass builds a register edge only in
 * behavioral context). The converter/combinational distinction of a
 * `ctor-stmt` is read at lowering time off the value head word
 * (`adc`/`comparator`/`dac`/`pwm` -> converter edge, else combinational).
 * `ports:`/`spec:`/`continuous:` bodies stay ordinary fields-with-bodies;
 * the lowering pass finds them by name.
 *)
on-block        = "on" , rest-of-line , [ INDENT , stmt-block , DEDENT ] ;
reg-assign      = name-path , "<=" , value-tail ;

(* E0193: a stray closing bracket at statement position -- the one
 * genuine in-body malformation. Recorded as an error node attributed to
 * the enclosing declaration subject (INV-20 per-subject gating). *)
subject-error   = ( ")" | "]" ) ;

field           = name-path , ":" , value-tail ;
ctor-stmt       = name-path , "=" , value-tail ;
name-path       = ident , { "." , ident } ;

value-tail      = [ value , [ during-clause ] ] , NEWLINE ,
                  [ INDENT , (* opaque continuation; see report note *) DEDENT ] ;

then-scope      = "then" , [ ident ] , [ "on" , expr ] , ":" , rest-of-line ,
                  [ INDENT , stmt-block , DEDENT ] ;

require-claim   = "require" , ident , ":" , rest-of-line ,
                  [ INDENT , stmt-block , DEDENT ] ;
                (* each claim line is a `field`: `subject: predicate`,
                   where `predicate` may start with a bare comparator
                   (`>= certified`) -- an implicit-subject shorthand,
                   see `expr` below *)

budget-stmt     = "budget" , rest-of-line , [ INDENT , stmt-block , DEDENT ] ;
waive-block     = "waive" , waive-target , [ "on" , query ] , ":" ,
                  [ INDENT , stmt-block , DEDENT ] ;
                (* body fields (parsed as ordinary `field`s the lowering
                   waiver pass reads back): mandatory `basis: <text>`;
                   optional `by <evidence>` (a deviation) and
                   `expires: <date>` (regolith/12 sec. 3). The header
                   `waive-target` is a claim path (`Group.claim`) or a
                   rule-pack rule (`dfm(rule)` / `drc(rule)` /
                   `erc(rule)`). *)
policy-block    = "policy" , rest-of-line , [ INDENT , stmt-block , DEDENT ] ;
locked-block    = "locked" , rest-of-line , [ INDENT , stmt-block , DEDENT ] ;

opaque-stmt     = rest-of-line , [ INDENT , (* raw, unstructured *) DEDENT ] ;

(* --- value sources (regolith/03) --------------------------------- *)

value           = cause-value | ( "in" , bracket-expr )
                | window-value | tolerance-value ;
cause-value     = "default" | "derived" | "free" | "allocated" ;
window-value    = "within" , bracket-expr ;   (* two-sided demanded window
                                                  `within [lo, hi]`; only when
                                                  a `[` follows -- the temporal
                                                  `within <dur> after <ev>`
                                                  claim form stays opaque *)
tolerance-value = expr , [ "+-" , expr , [ "%" ] ] ;
during-clause   = "during" , expr ;

(* --- expressions (Pratt precedence climbing) ---------------------- *)
(* precedence, loosest to tightest: comparisons < "+ -" < "* /" *)

expr            = comparison ;
comparison      = additive , { comparator , additive } ;
comparator      = "<" | ">" | "<=" | ">=" | "==" | "=" ;
additive        = multiplicative , { ( "+" | "-" ) , multiplicative } ;
multiplicative  = unary , { ( "*" | "/" ) , unary } ;
unary           = "-" , unary
                | comparator , unary   (* bound-only claim shorthand: an
                                          implicit-subject comparison,
                                          `trust: >= certified` *)
                | atom ;

atom            = quantity-lit
                | STRING
                | "(" , [ expr ] , ")"
                | bracket-expr
                | during-clause
                | cause-value
                | path-or-call
                ;

quantity-lit    = NUMBER , [ ident ] ;         (* unit immediately adjacent,
                                                   no whitespace: `5mm`, `1V` *)

path-or-call    = name-path , [ generic-args ] , [ "(" , arg-list , ")" ] ;
arg-list        = [ expr , { "," , expr } ] ;

(* use-site generic instantiation (`TappedHole<M3>`, `Decoder<3, 8>`,
 * nested `PatternOf<TappedHole<M3>>`): the head name plus a typed
 * generic-argument list (INV-11 monomorphization use sites). Mirrors
 * the decl-header `generic-params`; nested `<...>` are promoted to
 * nested instantiations.
 *
 * DISAMBIGUATION from the comparison operators `<`/`>` (which also
 * appear in claim expressions): a `<` is a generic-args opener ONLY
 * when it is GLUED to the head name (no whitespace) AND the angle
 * group scans as balanced, type-argument-like (identifiers, numbers,
 * commas, dots, colons, nested `<...>`), closing on the same logical
 * line, with an acceptable follower after `>` (`(`, `,`, `>`, `)`,
 * `]`, line end). Otherwise `<` stays a comparator. So `mass < 5kg`
 * (whitespace, no closing `>`) and `a < b and c > d` (an ident follows
 * the close) remain comparisons; `Foo<Bar>(...)` is an instantiation.
 * A genuinely ambiguous `<...>` that fails the scan is left opaque
 * (parsed as a comparison chain), never mis-attributed. *)
generic-args    = "<" , { any-token | generic-args } , ">" ;

(* `[a, b]` closed real interval vs `[i .. j]` half-open index range
 * (regolith/02 sec. 3); mixing both separators in one bracket, or a
 * range endpoint that carries a unit or a fractional literal, is a
 * genuine misuse flagged by regolith-syntax::checks (E0103). *)
bracket-expr    = "[" , [ expr , { ( "," , expr ) | ( ".." , expr ) } ] , "]" ;

(* --- lexical fragments (see crates/regolith-syntax/src/token.rs) -- *)

ident           = ? [A-Za-z_][A-Za-z0-9_]* ? ;
NUMBER          = ? [0-9]+(\.[0-9]+)?([eE][+-]?[0-9]+)? ? ;
STRING          = ? "([^"\\]|\\.)*" ? ;
rest-of-line    = { any-token } , NEWLINE ;
