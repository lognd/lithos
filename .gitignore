# Build artifacts
build/
dist/
*.egg-info/
cmake-build-*/
target/
*.o
*.a
*.so
*.dylib

# Python
.venv/
__pycache__/
*.pyc
.pytest_cache/
.ruff_cache/
.mypy_cache/
.coverage
htmlcov/
coverage.xml

# Project-local build state (AD-10): evidence cache + build state
.regolith/

# feldspar's own local evidence cache (WO-27 conformance run; the pack
# writes this in the invoking cwd, same posture as .regolith/ above)
.feldspar/

# frob local state
.frob/
FROBLEMS.md

# Secrets
.env

# Claude Code local state
.claude/

# JetBrains IDE
.idea/

# WO-108 proof-pack demo outputs: raw artifact BYTES are gitignored
# (regenerated by `make demos`); each demo's manifest.json + PROOF.md are
# committed evidence of shape and are force-added past this rule.
/demos/out/**
!/demos/out/
!/demos/out/*/
!/demos/out/*/manifest.json
!/demos/out/*/PROOF.md

# Local process/agent scratch markdowns -- working state, not repo content
# (TODO.md stays tracked: docs/workflow/README.md names it as THE live queue)
/CLAUDE.md
/FINDINGS*.md

# Playwright MCP session cruft
.playwright-mcp/
