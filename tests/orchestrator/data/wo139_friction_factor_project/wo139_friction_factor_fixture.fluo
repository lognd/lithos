# WO-139 (D258.3/F158 GAP a1) fixture: a single-segment `fluids.dp(...)`
# claim whose `friction_factor` is DERIVED (not inline-declared) from
# the std.fluid `[[roughness]]` record (`material=commercial_steel`)
# + the claim's own diameter/density/velocity + the medium's own
# resolved viscosity, via `FrictionFactorModel` (Haaland 1983,
# turbulent regime). Proves `orchestrator.translate` routes the
# derivation end to end, and that the calc package's citation +
# consumed-record-pin appendix both surface (WO-139 acceptance).

medium Water: liquid
    props: registry(water_iapws_liquid)

flownet TestLoop(medium=Water):
    reference: ambient(101kPa, 293K)
    nodes: a, b
    edges:
        seg: Pipe(from=lateral.run) (a -> b)

require Segment:
    dp: fluids.dp(a -> b, material=commercial_steel, length_m=2.0m, diameter_m=0.05m, density_kgm3=990.0kg/m3, velocity_ms=2.0m/s) <= 5000Pa
